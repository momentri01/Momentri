generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String       @id @default(uuid())
  email                   String       @unique
  fullName                String
  passwordHash            String
  role                    String       @default("USER")
  deliveryAddress         String?
  payoutInfo              String?
  bio                     String?
  phoneNumber             String?
  profileImageUrl         String?
  country                 String?
  province                String?
  businessName            String?
  registrationNumber      String?
  isCharity               Boolean      @default(false)
  stripeAccountId         String?      @unique
  stripeOnboardingComplete Boolean     @default(false)
  events                  Event[]
  withdrawals             Withdrawal[]
  campaigns               Campaign[]   @relation("OrganizationCampaigns")
  taxReceipts             TaxReceipt[] @relation("OrganizationTaxReceipts")
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

model Event {
  id                   String             @id @default(uuid())
  ownerId              String
  owner                User               @relation(fields: [ownerId], references: [id])
  eventType            String
  title                String
  description          String
  eventDate            DateTime
  coverImageUrl        String?
  donationGoal         Float
  currency             String             @default("USD")
  thankYouMessage      String?
  totalDonationsGross  Float @default(0)
  totalPlatformFees    Float @default(0)
  totalDonationsNet    Float @default(0)
  totalWishlistValue   Float @default(0)
  withdrawnAmount      Float @default(0)
  status               String             @default("ACTIVE")
  verificationStatus   String             @default("NONE") // NONE, PENDING, VERIFIED, REJECTED
  isVerified           Boolean            @default(false)
  visibility           String             @default("PUBLIC")
  country              String
  slug                 String             @unique
  donations            Donation[]
  wishlistItems        WishlistItem[]
  wishlistPurchases    WishlistPurchase[]
  withdrawals          Withdrawal[]
  reports              Report[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Donation {
  id                   String        @id @default(uuid())
  eventId              String? // Nullable as donations can be for events OR campaigns
  event                Event?        @relation(fields: [eventId], references: [id])
  campaignId           String? // Link to Campaign
  campaign             Campaign?     @relation(fields: [campaignId], references: [id]) // Back-relation to Campaign
  donorName            String
  donorEmail           String
  isAnonymous          Boolean       @default(false)
  grossAmount          Float
  platformFee          Float
  netAmount            Float
  currency             String
  paymentMethod        String
  paymentStatus        String        @default("PENDING")
  transactionReference String?       @unique
  message              String?
  createdAt            DateTime      @default(now())
}

model CatalogItem {
  id            String         @id @default(uuid())
  name          String
  description   String
  category      String
  price         Float
  currency      String         @default("USD")
  country       String         @default("United States")
  imageUrl      String?
  imageUrls     String         @default("[]")
  isActive      Boolean        @default(true)
  wishlistItems WishlistItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model WishlistItem {
  id                String             @id @default(uuid())
  eventId              String
  event                Event              @relation(fields: [eventId], references: [id])
  catalogItemId     String
  catalogItem       CatalogItem        @relation(fields: [catalogItemId], references: [id])
  itemName          String
  itemDescription   String
  itemImageUrl      String?
  price             Float
  currency          String
  quantityRequested Int
  quantityPurchased Int                @default(0)
  status            String             @default("ACTIVE")
  purchases         WishlistPurchase[]
  createdAt           DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model WishlistPurchase {
  id                   String            @id @default(uuid())
  eventId              String
  event                Event             @relation(fields: [eventId], references: [id])
  wishlistItemId       String
  wishlistItem         WishlistItem      @relation(fields: [wishlistItemId], references: [id])
  itemName             String
  buyerName            String
  buyerEmail           String
  isAnonymous          Boolean           @default(false)
  quantity             Int
  grossAmount          Float
  platformFee          Float
  netAmount            Float
  currency             String
  paymentMethod        String
  paymentStatus        String            @default("PENDING")
  fulfillmentStatus    String            @default("PENDING")
  transactionReference String?           @unique
  message              String?
  createdAt            DateTime          @default(now())
}

model Withdrawal {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  userEmail     String
  eventId       String
  event         Event            @relation(fields: [eventId], references: [id])
  eventTitle    String
  amount        Float
  currency      String
  payoutMethod  String
  payoutDetails String?
  status        String           @default("PENDING")
  adminNotes    String?
  processedAt   DateTime?
  createdAt     DateTime         @default(now())
}

model Report {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  reporterEmail String
  reason      String
  details     String?
  status      String   @default("PENDING") // PENDING, REVIEWED, RESOLVED
  createdAt   DateTime @default(now())
}

model Campaign {
  id                 String       @id @default(uuid())
  organizationId     String
  organization       User         @relation("OrganizationCampaigns", fields: [organizationId], references: [id])
  title              String
  description        String
  campaignGoal       Float
  currency           String       @default("USD")
  startDate          DateTime
  endDate            DateTime?
  status             String       @default("ACTIVE") // e.g., ACTIVE, COMPLETED, ARCHIVED
  coverImageUrl      String?
  totalDonationsGross Float @default(0)
  totalPlatformFees  Float @default(0)
  totalDonationsNet  Float @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  donations          Donation[]
}

model TaxReceipt {
  id                 String    @id @default(uuid())
  donationId         String?   // Optional: Link to a specific donation
  campaignId         String?   // Optional: Link to a specific campaign
  organizationId     String
  organization       User      @relation("OrganizationTaxReceipts", fields: [organizationId], references: [id])
  donorName          String
  donorEmail         String
  amount             Float
  currency           String
  dateIssued         DateTime  @default(now())
  receiptNumber      String    @unique
  organizationTaxId  String?
  issuedBy           String?   // e.g., "Momentris" or organization name
}